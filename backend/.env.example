# ============================================================================
# CLOUD HEROES AFRICA - BACKEND ENVIRONMENT CONFIGURATION
# ============================================================================

# SERVER CONFIGURATION
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# MONGODB ATLAS DATABASE
# Get from: https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/cloudheroes

# JWT CONFIGURATION
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRE=30d

# GOOGLE OAUTH 2.0 (Students & Donors)
# Get from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# MICROSOFT ENTRA ID / AZURE AD (Administrators & Volunteers)
# Get from: https://portal.azure.com/
AZURE_CLIENT_ID=your_azure_client_id
AZURE_TENANT_ID=your_azure_tenant_id
AZURE_CLIENT_SECRET=your_azure_client_secret
AZURE_CALLBACK_URL=http://localhost:5000/api/auth/azure/callback

# STRIPE PAYMENT GATEWAY
# Get from: https://stripe.com/
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# PAYPAL PAYMENT GATEWAY
# Get from: https://developer.paypal.com/
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# MTN MOBILE MONEY (Cameroon)
# Get from: https://momodeveloper.mtn.com/
MTN_MOMO_API_KEY=your_mtn_api_key
MTN_MOMO_API_SECRET=your_mtn_api_secret
MTN_MOMO_SUBSCRIPTION_KEY=your_mtn_subscription_key
MTN_MOMO_ENVIRONMENT=sandbox
MTN_MOMO_CALLBACK_URL=http://localhost:5000/api/payments/mtn/callback

# ORANGE MONEY (Cameroon)
# Get from: https://developer.orange.com/
ORANGE_MONEY_API_KEY=your_orange_api_key
ORANGE_MONEY_API_SECRET=your_orange_api_secret
ORANGE_MONEY_MERCHANT_ID=your_merchant_id
ORANGE_MONEY_ENVIRONMENT=sandbox
ORANGE_MONEY_CALLBACK_URL=http://localhost:5000/api/payments/orange/callback

# GMAIL EMAIL SERVICE
# Get from: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
EMAIL_FROM=Cloud Heroes Africa <noreply@cloudheroes.africa>

# SESSION CONFIGURATION
SESSION_SECRET=your_session_secret_here
SESSION_TIMEOUT=1800000

# MFA GRACE PERIODS (days)
MFA_GRACE_STUDENT=14
MFA_GRACE_DONOR=30
MFA_GRACE_ADMIN=0
MFA_GRACE_VOLUNTEER=0

# RATE LIMITING
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# AUDIT LOGGING
AUDIT_LOG_RETENTION_DAYS=365
