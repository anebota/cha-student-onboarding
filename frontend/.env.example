# ============================================================================
# CLOUD HEROES AFRICA - FRONTEND ENVIRONMENT CONFIGURATION
# ============================================================================
# 
# INSTRUCTIONS:
# 1. Copy this file and rename it to ".env"
# 2. Follow the step-by-step instructions below
# 3. Replace all placeholder values with your actual values
# 4. NEVER commit the .env file to version control (it's in .gitignore)
# 
# IMPORTANT: All Vite environment variables MUST start with "VITE_"
# 
# ============================================================================

# ============================================================================
# API CONFIGURATION
# ============================================================================
# These tell your frontend where to find the backend API

VITE_API_URL=http://localhost:5000
# The base URL of your backend API
# 
# Development (local):
#   http://localhost:5000
# 
# Production:
#   https://api.yourdomain.com
#   (Replace with your actual production API URL)
# 
# IMPORTANT: 
# - Do NOT include /api at the end
# - Do NOT include a trailing slash
# - Must match where your backend is running

VITE_SOCKET_URL=http://localhost:5000
# The URL for Socket.io real-time connection
# 
# Development (local):
#   http://localhost:5000
# 
# Production:
#   https://api.yourdomain.com
#   (Same as your API URL)
# 
# IMPORTANT:
# - Usually the same as VITE_API_URL
# - Socket.io connects to the same server as the API

# ============================================================================
# OAUTH AUTHENTICATION URLS
# ============================================================================
# These are the URLs that initiate OAuth login flows

VITE_GOOGLE_AUTH_URL=http://localhost:5000/api/auth/google
# Google OAuth login URL (for Students and Donors)
# 
# Development:
#   http://localhost:5000/api/auth/google
# 
# Production:
#   https://api.yourdomain.com/api/auth/google
# 
# How it works:
# - User clicks "Login with Google" button
# - Frontend redirects to this URL
# - Backend handles OAuth flow with Google
# - User is redirected back after authentication

VITE_AZURE_AUTH_URL=http://localhost:5000/api/auth/azure
# Microsoft Entra ID (Azure AD) login URL (for Administrators and Volunteers)
# 
# Development:
#   http://localhost:5000/api/auth/azure
# 
# Production:
#   https://api.yourdomain.com/api/auth/azure
# 
# How it works:
# - User clicks "Login with Microsoft" button
# - Frontend redirects to this URL
# - Backend handles OAuth flow with Microsoft
# - User is redirected back after authentication

# ============================================================================
# STRIPE PAYMENT GATEWAY
# ============================================================================
# STEP-BY-STEP SETUP:
# 
# 1. Log in to Stripe Dashboard: https://dashboard.stripe.com/
# 2. Make sure you're in "Test mode" (toggle at top right)
# 3. Go to: Developers → API keys
# 4. Find "Publishable key" (starts with pk_test_)
# 5. Copy the publishable key and paste below
# 
# IMPORTANT:
# - Use pk_test_ for development/testing
# - Use pk_live_ for production
# - The publishable key is safe to expose in frontend code
# - NEVER put the secret key (sk_) in frontend!
# 
# For Production:
# 1. Toggle to "Live mode" in Stripe Dashboard
# 2. Get the live publishable key (pk_live_)
# 3. Replace the test key with the live key

VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
# REPLACE with your Stripe Publishable Key
# 
# Test key format:
#   pk_test_51XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# 
# Live key format:
#   pk_live_51XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# 
# Example:
#   pk_test_51A1B2C3D4E5F6G7H8I9J0K1L2M3N4O5P6Q7R8S9T0U1V2W3X4Y5Z6A7B8C9D0
# 
# Where to find it:
#   Stripe Dashboard → Developers → API keys → Publishable key

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
# General app settings

VITE_APP_NAME=Cloud Heroes Africa
# The name of your application
# Used in page titles, headers, etc.
# You can customize this if needed

VITE_APP_URL=http://localhost:5173
# The URL where your frontend is running
# 
# Development (Vite default):
#   http://localhost:5173
# 
# Production:
#   https://yourdomain.com
#   (Replace with your actual domain)
# 
# Used for:
# - OAuth redirect URIs
# - Email links
# - Social sharing

# ============================================================================
# OPTIONAL: ADDITIONAL CONFIGURATION
# ============================================================================
# You can add more environment variables as needed

# VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# Google Analytics tracking ID (if you use it)

# VITE_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
# Sentry error tracking DSN (if you use it)

# VITE_ENABLE_DEBUG=false
# Enable debug mode (true/false)

# ============================================================================
# HOW TO USE ENVIRONMENT VARIABLES IN YOUR CODE
# ============================================================================
# 
# In any React component or JavaScript file:
# 
# import.meta.env.VITE_API_URL
# import.meta.env.VITE_STRIPE_PUBLISHABLE_KEY
# 
# Example:
# 
# const apiUrl = import.meta.env.VITE_API_URL;
# console.log('API URL:', apiUrl);
# 
# const stripeKey = import.meta.env.VITE_STRIPE_PUBLISHABLE_KEY;
# const stripe = loadStripe(stripeKey);
# 
# ============================================================================

# ============================================================================
# TROUBLESHOOTING
# ============================================================================
# 
# Problem: Environment variables not working
# Solution: 
# - Make sure variable names start with VITE_
# - Restart the dev server after changing .env
# - Check for typos in variable names
# 
# Problem: API calls failing with CORS error
# Solution:
# - Make sure VITE_API_URL matches your backend URL exactly
# - Check that backend FRONTEND_URL matches this frontend URL
# - Ensure backend CORS is configured correctly
# 
# Problem: OAuth login not working
# Solution:
# - Verify VITE_GOOGLE_AUTH_URL and VITE_AZURE_AUTH_URL are correct
# - Check that backend OAuth credentials are configured
# - Ensure redirect URIs match in OAuth provider settings
# 
# Problem: Stripe payments not working
# Solution:
# - Verify you're using the correct publishable key (pk_test_ or pk_live_)
# - Check that backend has the matching secret key
# - Ensure you're in the correct mode (test/live) in Stripe Dashboard
# 
# ============================================================================

# ============================================================================
# SETUP CHECKLIST
# ============================================================================
# 
# Before starting development:
# ✓ Copy this file to .env
# ✓ Set VITE_API_URL to your backend URL
# ✓ Set VITE_SOCKET_URL (usually same as API URL)
# ✓ Set OAuth URLs if using authentication
# ✓ Set Stripe key if using payments
# ✓ Save the file
# ✓ Restart dev server: npm run dev
# ✓ Test in browser: http://localhost:5173
# 
# Minimum required to start:
# - VITE_API_URL
# - VITE_SOCKET_URL
# 
# Optional (can add later):
# - OAuth URLs (if using Google/Microsoft login)
# - Stripe key (if accepting payments)
# 
# ============================================================================

# ============================================================================
# PRODUCTION DEPLOYMENT
# ============================================================================
# 
# When deploying to production:
# 
# 1. Update all URLs to production values:
#    VITE_API_URL=https://api.yourdomain.com
#    VITE_SOCKET_URL=https://api.yourdomain.com
#    VITE_GOOGLE_AUTH_URL=https://api.yourdomain.com/api/auth/google
#    VITE_AZURE_AUTH_URL=https://api.yourdomain.com/api/auth/azure
#    VITE_APP_URL=https://yourdomain.com
# 
# 2. Use production Stripe key:
#    VITE_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx
# 
# 3. Build the application:
#    npm run build
# 
# 4. Deploy the dist/ folder to your hosting service
# 
# 5. Set environment variables in your hosting platform:
#    - Vercel: Project Settings → Environment Variables
#    - Netlify: Site Settings → Build & Deploy → Environment
#    - AWS Amplify: App Settings → Environment Variables
# 
# ============================================================================

# ============================================================================
# SECURITY NOTES
# ============================================================================
# 
# ✓ DO commit .env.example to version control
# ✗ DO NOT commit .env to version control
# ✓ DO use different values for development and production
# ✗ DO NOT share your .env file with anyone
# ✓ DO use environment variables in hosting platform for production
# ✗ DO NOT hardcode sensitive values in your code
# 
# The .env file should be in .gitignore to prevent accidental commits
# 
# ============================================================================

